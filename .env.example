# Copy this file to .env and fill in your values:  cp .env.example .env
#
# Base URL of your GitLab instance (no trailing slash).
GITLAB_URL=https://gitlab.your-company.com

# Personal access token with the `read_api` scope.
# Create one at: <GITLAB_URL>/-/user_settings/personal_access_tokens
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx

# Watch every member of this group (id or full path). Optional if GITLAB_USERS is set.
GITLAB_GROUP=org/myteam

# OR/also watch specific usernames (comma-separated). Optional if GITLAB_GROUP is set.
# GITLAB_USERS=aziz,dilnoza,sardor

# How often to poll GitLab, in seconds.
POLL_INTERVAL=30

# Max number of member event-fetches to run in parallel each poll.
# FETCH_CONCURRENCY=8

# Required: Discord channel webhook. Every NEW event (after the first priming
# poll) is posted here. The first poll loads the backlog silently.
# Create one in Discord: Server → Channel → Edit → Integrations → Webhooks → New.
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/XXXXXXXX/YYYYYYYY
